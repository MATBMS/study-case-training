<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_N1" targetNamespace="http://nsi-training/study-case/bpmn" exporter="Camunda Web Modeler" exporterVersion="a89018a" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:collaboration id="Collaboration_N1">
    <bpmn:participant id="Pool_Client" name="Client (boîte noire)" />
    <bpmn:participant id="Pool_NovaTrade" name="NovaTrade" processRef="Process_NovaTrade_N1" />
    <bpmn:participant id="Pool_Transporteur" name="Transporteur (boîte noire)" />
    <bpmn:messageFlow id="MF_Commande" name="Commande" sourceRef="Pool_Client" targetRef="StartEvent_Commande" />
    <bpmn:messageFlow id="MF_Confirmation" name="Confirmation" sourceRef="SP1" targetRef="Pool_Client" />
    <bpmn:messageFlow id="MF_DemandeCollecte" name="Demande de collecte" sourceRef="SP2" targetRef="Pool_Transporteur" />
    <bpmn:messageFlow id="MF_Suivi" name="Suivi / Livraison" sourceRef="Pool_Transporteur" targetRef="SP2" />
    <bpmn:messageFlow id="MF_NotifExp" name="Notification expédition" sourceRef="SP2" targetRef="Pool_Client" />
    <bpmn:messageFlow id="MF_Facture" name="Facture" sourceRef="SP3" targetRef="Pool_Client" />
    <bpmn:messageFlow id="MF_Paiement" name="Paiement" sourceRef="Pool_Client" targetRef="SP3" />
    <bpmn:messageFlow id="MF_ConfirmationPay" name="Confirmation paiement" sourceRef="SP3" targetRef="Pool_Client" />
  </bpmn:collaboration>
  <bpmn:process id="Process_NovaTrade_N1" isExecutable="false">
    <bpmn:laneSet id="LaneSet_NT">
      <bpmn:lane id="Lane_Vente" name="Vente">
        <bpmn:flowNodeRef>StartEvent_Commande</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>XOR1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndReject</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndHold</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SP1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Finance" name="Finance">
        <bpmn:flowNodeRef>EndOK</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>XOR2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEsc</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SP3</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Execution" name="Exécution">
        <bpmn:flowNodeRef>SP2</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:sequenceFlow id="SF_Start_SP1" sourceRef="StartEvent_Commande" targetRef="SP1" />
    <bpmn:sequenceFlow id="SF_SP1_XOR1" sourceRef="SP1" targetRef="XOR1" />
    <bpmn:sequenceFlow id="SF_XOR1_Reject" name="Rejet" sourceRef="XOR1" targetRef="EndReject" />
    <bpmn:sequenceFlow id="SF_XOR1_Hold" name="OnHold" sourceRef="XOR1" targetRef="EndHold" />
    <bpmn:sequenceFlow id="SF_XOR1_SP2" name="Confirmée" sourceRef="XOR1" targetRef="SP2" />
    <bpmn:sequenceFlow id="SF_SP2_SP3" sourceRef="SP2" targetRef="SP3" />
    <bpmn:sequenceFlow id="SF_SP3_XOR2" sourceRef="SP3" targetRef="XOR2" />
    <bpmn:sequenceFlow id="SF_XOR2_OK" name="Payée" sourceRef="XOR2" targetRef="EndOK" />
    <bpmn:sequenceFlow id="SF_XOR2_Esc" name="3 relances sans paiement" sourceRef="XOR2" targetRef="EndEsc" />
    <bpmn:startEvent id="StartEvent_Commande" name="Commande reçue">
      <bpmn:outgoing>SF_Start_SP1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_Start" />
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="XOR1" name="Résultat ?">
      <bpmn:incoming>SF_SP1_XOR1</bpmn:incoming>
      <bpmn:outgoing>SF_XOR1_Reject</bpmn:outgoing>
      <bpmn:outgoing>SF_XOR1_Hold</bpmn:outgoing>
      <bpmn:outgoing>SF_XOR1_SP2</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndReject" name="Commande rejetée">
      <bpmn:incoming>SF_XOR1_Reject</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_Reject" />
    </bpmn:endEvent>
    <bpmn:endEvent id="EndHold" name="Commande OnHold">
      <bpmn:incoming>SF_XOR1_Hold</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_Hold" />
    </bpmn:endEvent>
    <bpmn:subProcess id="SP1" name="1. Recevoir et confirmer la commande">
      <bpmn:incoming>SF_Start_SP1</bpmn:incoming>
      <bpmn:outgoing>SF_SP1_XOR1</bpmn:outgoing>
    </bpmn:subProcess>
    <bpmn:subProcess id="SP2" name="2. Préparer et expédier la commande">
      <bpmn:incoming>SF_XOR1_SP2</bpmn:incoming>
      <bpmn:outgoing>SF_SP2_SP3</bpmn:outgoing>
    </bpmn:subProcess>
    <bpmn:endEvent id="EndOK" name="Commande clôturée">
      <bpmn:incoming>SF_XOR2_OK</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="XOR2" name="Résultat ?">
      <bpmn:incoming>SF_SP3_XOR2</bpmn:incoming>
      <bpmn:outgoing>SF_XOR2_OK</bpmn:outgoing>
      <bpmn:outgoing>SF_XOR2_Esc</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEsc" name="Escalade recouvrement">
      <bpmn:incoming>SF_XOR2_Esc</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_Esc" />
    </bpmn:endEvent>
    <bpmn:subProcess id="SP3" name="3. Facturer et encaisser">
      <bpmn:incoming>SF_SP2_SP3</bpmn:incoming>
      <bpmn:outgoing>SF_SP3_XOR2</bpmn:outgoing>
    </bpmn:subProcess>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_N1">
    <bpmndi:BPMNPlane id="BPMNPlane_N1" bpmnElement="Collaboration_N1">
