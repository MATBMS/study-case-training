<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_N0"
                  targetNamespace="http://nsi-training/study-case/bpmn">

  <bpmn:collaboration id="Collaboration_N0">
    <bpmn:participant id="Pool_Client" name="Client (boîte noire)"/>
    <bpmn:participant id="Pool_OMS" name="OMS NovaTrade — Processus Order-to-Cash"/>
    <bpmn:participant id="Pool_Transporteur" name="Transporteur (boîte noire)"/>

    <bpmn:messageFlow id="MF_Commande"          name="Commande"                       sourceRef="Pool_Client"        targetRef="Pool_OMS"/>
    <bpmn:messageFlow id="MF_ConfirmationCmd"   name="Confirmation de commande"       sourceRef="Pool_OMS"           targetRef="Pool_Client"/>
    <bpmn:messageFlow id="MF_NotifExp"          name="Notification d'expédition"      sourceRef="Pool_OMS"           targetRef="Pool_Client"/>
    <bpmn:messageFlow id="MF_Facture"           name="Facture"                        sourceRef="Pool_OMS"           targetRef="Pool_Client"/>
    <bpmn:messageFlow id="MF_Paiement"          name="Paiement"                       sourceRef="Pool_Client"        targetRef="Pool_OMS"/>
    <bpmn:messageFlow id="MF_ConfirmationPay"   name="Confirmation de paiement"       sourceRef="Pool_OMS"           targetRef="Pool_Client"/>
    <bpmn:messageFlow id="MF_DemandeCollecte"   name="Demande de collecte"            sourceRef="Pool_OMS"           targetRef="Pool_Transporteur"/>
    <bpmn:messageFlow id="MF_Suivi"             name="Suivi / Confirmation livraison" sourceRef="Pool_Transporteur"  targetRef="Pool_OMS"/>
  </bpmn:collaboration>

  <bpmndi:BPMNDiagram id="BPMNDiagram_N0">
    <bpmndi:BPMNPlane id="BPMNPlane_N0" bpmnElement="Collaboration_N0">

      <bpmndi:BPMNShape id="Pool_Client_di" bpmnElement="Pool_Client" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="900" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Pool_OMS_di" bpmnElement="Pool_OMS" isHorizontal="true">
        <dc:Bounds x="160" y="240" width="900" height="200"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Pool_Transporteur_di" bpmnElement="Pool_Transporteur" isHorizontal="true">
        <dc:Bounds x="160" y="520" width="900" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="MF_Commande_di" bpmnElement="MF_Commande">
        <di:waypoint x="260" y="160"/>
        <di:waypoint x="260" y="240"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_ConfirmationCmd_di" bpmnElement="MF_ConfirmationCmd">
        <di:waypoint x="360" y="240"/>
        <di:waypoint x="360" y="160"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_NotifExp_di" bpmnElement="MF_NotifExp">
        <di:waypoint x="460" y="240"/>
        <di:waypoint x="460" y="160"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_Facture_di" bpmnElement="MF_Facture">
        <di:waypoint x="600" y="240"/>
        <di:waypoint x="600" y="160"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_Paiement_di" bpmnElement="MF_Paiement">
        <di:waypoint x="720" y="160"/>
        <di:waypoint x="720" y="240"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_ConfirmationPay_di" bpmnElement="MF_ConfirmationPay">
        <di:waypoint x="840" y="240"/>
        <di:waypoint x="840" y="160"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_DemandeCollecte_di" bpmnElement="MF_DemandeCollecte">
        <di:waypoint x="500" y="440"/>
        <di:waypoint x="500" y="520"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_Suivi_di" bpmnElement="MF_Suivi">
        <di:waypoint x="640" y="520"/>
        <di:waypoint x="640" y="440"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
