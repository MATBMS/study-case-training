<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_N23"
                  targetNamespace="http://nsi-training/study-case/bpmn">

  <bpmn:collaboration id="Collaboration_N23">
    <bpmn:participant id="Pool_Client" name="Client (boîte noire)"/>
    <bpmn:participant id="Pool_Finance" name="NovaTrade — Finance (Facturer et encaisser)" processRef="Process_Finance"/>

    <bpmn:messageFlow id="MF_Facture"        name="Facture"               sourceRef="T2_SendInvoice" targetRef="Pool_Client"/>
    <bpmn:messageFlow id="MF_Paiement"       name="Paiement"              sourceRef="Pool_Client"    targetRef="Wait_Pay"/>
    <bpmn:messageFlow id="MF_ConfirmPaiement" name="Confirmation paiement" sourceRef="EndPaid"        targetRef="Pool_Client"/>
  </bpmn:collaboration>

  <bpmn:process id="Process_Finance" isExecutable="false">

    <bpmn:startEvent id="Start_Disp" name="Expédition Dispatched">
      <bpmn:outgoing>SF_Start_T1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="T1_GenInvoice" name="Générer la facture (BR-11)">
      <bpmn:incoming>SF_Start_T1</bpmn:incoming>
      <bpmn:outgoing>SF_T1_T2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="T2_SendInvoice" name="Envoyer la facture au Client">
      <bpmn:incoming>SF_T1_T2</bpmn:incoming>
      <bpmn:outgoing>SF_T2_T3</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:serviceTask id="T3_PostERP" name="Publier la créance dans l'ERP">
      <bpmn:incoming>SF_T2_T3</bpmn:incoming>
      <bpmn:outgoing>SF_T3_EBG</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:eventBasedGateway id="EBG" name="Attente paiement ou échéance">
      <bpmn:incoming>SF_T3_EBG</bpmn:incoming>
      <bpmn:outgoing>SF_EBG_Pay</bpmn:outgoing>
      <bpmn:outgoing>SF_EBG_Due</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="Wait_Pay" name="Paiement reçu">
      <bpmn:incoming>SF_EBG_Pay</bpmn:incoming>
      <bpmn:outgoing>SF_Pay_T4</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_Pay"/>
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="Wait_Due" name="Date d'échéance atteinte">
      <bpmn:incoming>SF_EBG_Due</bpmn:incoming>
      <bpmn:outgoing>SF_Due_T6</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_Due"/>
    </bpmn:intermediateCatchEvent>

    <bpmn:serviceTask id="T6_MarkOverdue" name="Marquer la facture Overdue (BR-12)">
      <bpmn:incoming>SF_Due_T6</bpmn:incoming>
      <bpmn:outgoing>SF_T6_SP</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:subProcess id="SP_Relance" name="Relancer le client (jusqu'à 3 fois — BR-13)">
      <bpmn:incoming>SF_T6_SP</bpmn:incoming>
      <bpmn:outgoing>SF_SP_XOR</bpmn:outgoing>
    </bpmn:subProcess>

    <bpmn:exclusiveGateway id="XOR_Relance" name="Paiement reçu après relances ?">
      <bpmn:incoming>SF_SP_XOR</bpmn:incoming>
      <bpmn:outgoing>SF_XOR_Oui</bpmn:outgoing>
      <bpmn:outgoing>SF_XOR_Non</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="T4_Capture" name="Capturer le paiement via Passerelle (BR-14)">
      <bpmn:incoming>SF_Pay_T4</bpmn:incoming>
      <bpmn:incoming>SF_XOR_Oui</bpmn:incoming>
      <bpmn:outgoing>SF_T4_T5</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="T5_Reconcile" name="Marquer Paid + rapprocher dans l'ERP (BR-15)">
      <bpmn:incoming>SF_T4_T5</bpmn:incoming>
      <bpmn:outgoing>SF_T5_End</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndPaid" name="Facture payée (commande clôturée)">
      <bpmn:incoming>SF_T5_End</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndPaid"/>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEsc" name="Escalade recouvrement">
      <bpmn:incoming>SF_XOR_Non</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_EndEsc"/>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="SF_Start_T1"  sourceRef="Start_Disp"      targetRef="T1_GenInvoice"/>
    <bpmn:sequenceFlow id="SF_T1_T2"     sourceRef="T1_GenInvoice"   targetRef="T2_SendInvoice"/>
    <bpmn:sequenceFlow id="SF_T2_T3"     sourceRef="T2_SendInvoice"  targetRef="T3_PostERP"/>
    <bpmn:sequenceFlow id="SF_T3_EBG"    sourceRef="T3_PostERP"      targetRef="EBG"/>
    <bpmn:sequenceFlow id="SF_EBG_Pay"   sourceRef="EBG"             targetRef="Wait_Pay"/>
    <bpmn:sequenceFlow id="SF_EBG_Due"   sourceRef="EBG"             targetRef="Wait_Due"/>
    <bpmn:sequenceFlow id="SF_Pay_T4"    sourceRef="Wait_Pay"        targetRef="T4_Capture"/>
    <bpmn:sequenceFlow id="SF_Due_T6"    sourceRef="Wait_Due"        targetRef="T6_MarkOverdue"/>
    <bpmn:sequenceFlow id="SF_T6_SP"     sourceRef="T6_MarkOverdue"  targetRef="SP_Relance"/>
    <bpmn:sequenceFlow id="SF_SP_XOR"    sourceRef="SP_Relance"      targetRef="XOR_Relance"/>
    <bpmn:sequenceFlow id="SF_XOR_Oui"   name="Oui"                       sourceRef="XOR_Relance" targetRef="T4_Capture"/>
    <bpmn:sequenceFlow id="SF_XOR_Non"   name="Non — 3 relances sans paiement" sourceRef="XOR_Relance" targetRef="EndEsc"/>
    <bpmn:sequenceFlow id="SF_T4_T5"     sourceRef="T4_Capture"      targetRef="T5_Reconcile"/>
    <bpmn:sequenceFlow id="SF_T5_End"    sourceRef="T5_Reconcile"    targetRef="EndPaid"/>
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_N23">
    <bpmndi:BPMNPlane id="BPMNPlane_N23" bpmnElement="Collaboration_N23">

      <bpmndi:BPMNShape id="Pool_Client_di" bpmnElement="Pool_Client" isHorizontal="true">
        <dc:Bounds x="160" y="60" width="2000" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Pool_Finance_di" bpmnElement="Pool_Finance" isHorizontal="true">
        <dc:Bounds x="160" y="180" width="2000" height="500"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Start_Disp_di" bpmnElement="Start_Disp">
        <dc:Bounds x="220" y="412" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="200" y="455" width="80" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="T1_di" bpmnElement="T1_GenInvoice">
        <dc:Bounds x="300" y="390" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="T2_di" bpmnElement="T2_SendInvoice">
        <dc:Bounds x="480" y="390" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="T3_di" bpmnElement="T3_PostERP">
        <dc:Bounds x="660" y="390" width="140" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EBG_di" bpmnElement="EBG">
        <dc:Bounds x="850" y="405" width="50" height="50"/>
        <bpmndi:BPMNLabel><dc:Bounds x="830" y="365" width="100" height="28"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Wait_Pay_di" bpmnElement="Wait_Pay">
        <dc:Bounds x="950" y="302" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="930" y="270" width="80" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Wait_Due_di" bpmnElement="Wait_Due">
        <dc:Bounds x="950" y="522" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="930" y="565" width="80" height="28"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="T6_di" bpmnElement="T6_MarkOverdue">
        <dc:Bounds x="1040" y="500" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SP_Relance_di" bpmnElement="SP_Relance" isExpanded="false">
        <dc:Bounds x="1220" y="500" width="180" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="XOR_Relance_di" bpmnElement="XOR_Relance" isMarkerVisible="true">
        <dc:Bounds x="1450" y="515" width="50" height="50"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1430" y="475" width="100" height="28"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEsc_di" bpmnElement="EndEsc">
        <dc:Bounds x="1550" y="600" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1530" y="640" width="80" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="T4_di" bpmnElement="T4_Capture">
        <dc:Bounds x="1620" y="390" width="160" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="T5_di" bpmnElement="T5_Reconcile">
        <dc:Bounds x="1820" y="390" width="180" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndPaid_di" bpmnElement="EndPaid">
        <dc:Bounds x="2050" y="412" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="2025" y="455" width="100" height="28"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="SF_Start_T1_di" bpmnElement="SF_Start_T1">
        <di:waypoint x="256" y="430"/>
        <di:waypoint x="300" y="430"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SF_T1_T2_di" bpmnElement="SF_T1_T2">
        <di:waypoint x="440" y="430"/>
        <di:waypoint x="480" y="430"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SF_T2_T3_di" bpmnElement="SF_T2_T3">
        <di:waypoint x="620" y="430"/>
        <di:waypoint x="660" y="430"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SF_T3_EBG_di" bpmnElement="SF_T3_EBG">
        <di:waypoint x="800" y="430"/>
        <di:waypoint x="850" y="430"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SF_EBG_Pay_di" bpmnElement="SF_EBG_Pay">
        <di:waypoint x="875" y="405"/>
        <di:waypoint x="875" y="320"/>
        <di:waypoint x="950" y="320"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SF_EBG_Due_di" bpmnElement="SF_EBG_Due">
        <di:waypoint x="875" y="455"/>
        <di:waypoint x="875" y="540"/>
        <di:waypoint x="950" y="540"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SF_Pay_T4_di" bpmnElement="SF_Pay_T4">
        <di:waypoint x="986" y="320"/>
        <di:waypoint x="1700" y="320"/>
        <di:waypoint x="1700" y="390"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SF_Due_T6_di" bpmnElement="SF_Due_T6">
        <di:waypoint x="986" y="540"/>
        <di:waypoint x="1040" y="540"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SF_T6_SP_di" bpmnElement="SF_T6_SP">
        <di:waypoint x="1180" y="540"/>
        <di:waypoint x="1220" y="540"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SF_SP_XOR_di" bpmnElement="SF_SP_XOR">
        <di:waypoint x="1400" y="540"/>
        <di:waypoint x="1450" y="540"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SF_XOR_Oui_di" bpmnElement="SF_XOR_Oui">
        <di:waypoint x="1500" y="540"/>
        <di:waypoint x="1700" y="540"/>
        <di:waypoint x="1700" y="470"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SF_XOR_Non_di" bpmnElement="SF_XOR_Non">
        <di:waypoint x="1475" y="565"/>
        <di:waypoint x="1475" y="618"/>
        <di:waypoint x="1550" y="618"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SF_T4_T5_di" bpmnElement="SF_T4_T5">
        <di:waypoint x="1780" y="430"/>
        <di:waypoint x="1820" y="430"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SF_T5_End_di" bpmnElement="SF_T5_End">
        <di:waypoint x="2000" y="430"/>
        <di:waypoint x="2050" y="430"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MF_Facture_di" bpmnElement="MF_Facture">
        <di:waypoint x="550" y="390"/>
        <di:waypoint x="550" y="140"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_Paiement_di" bpmnElement="MF_Paiement">
        <di:waypoint x="968" y="140"/>
        <di:waypoint x="968" y="302"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_ConfirmPaiement_di" bpmnElement="MF_ConfirmPaiement">
        <di:waypoint x="2068" y="412"/>
        <di:waypoint x="2068" y="140"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
