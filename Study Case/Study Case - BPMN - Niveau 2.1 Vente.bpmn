        <di:waypoint x="1260" y="140" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1178" y="203" width="63" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_Rejet_di" bpmnElement="MF_Rejet">
        <di:waypoint x="868" y="232" />
        <di:waypoint x="868" y="140" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="880" y="193" width="79" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
